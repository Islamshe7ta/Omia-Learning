<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة الإدارة المركزية</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root {
            --color-1000: #583101;
            --color-900: #603808;
            --color-800: #6F4518;
            --color-700: #8B5E34;
            --color-600: #A47148;
            --color-500: #BC8A5F;
            --color-400: #D4A276;
            --color-300: #E7BC91;
            --color-200: #F3D5B5;
            --color-100: #FFEED8;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--color-100);
            color: #2d1a00;
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .admin-navbar {
            background: var(--color-1000);
            padding: 0 1.5rem;
            box-shadow: 0 2px 8px rgba(88,49,1,.3);
            min-height: 64px;
        }

        .admin-navbar .navbar-brand {
            color: var(--color-100) !important;
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: -.5px;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .admin-navbar .nav-link {
            color: var(--color-300) !important;
            font-weight: 600;
            font-size: .9rem;
            padding: .5rem .85rem !important;
            border-radius: 8px;
            transition: background .2s, color .2s;
        }

        .admin-navbar .nav-link:hover,
        .admin-navbar .nav-link.active {
            color: #fff !important;
            background: var(--color-800);
        }

        .admin-navbar .navbar-text {
            color: var(--color-200) !important;
            font-size: .88rem;
        }

        .btn-logout {
            background: var(--color-800);
            color: var(--color-100) !important;
            border: none;
            border-radius: 8px;
            padding: .35rem .9rem;
            font-weight: 600;
            font-size: .88rem;
            text-decoration: none;
            transition: background .2s;
        }

        .btn-logout:hover {
            background: var(--color-600);
            color: #fff !important;
        }

        /* ── Main container ── */
        .main-content {
            padding: 2rem 1.5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── Page header ── */
        .page-header {
            margin-bottom: 1.75rem;
        }

        .page-header h1 {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--color-1000);
            margin: 0;
        }

        .page-header .breadcrumb {
            margin: 0;
            font-size: .85rem;
        }

        .page-header .breadcrumb-item a {
            color: var(--color-600);
            text-decoration: none;
        }

        /* ── Buttons ── */
        .btn-primary {
            background: var(--color-1000) !important;
            border-color: var(--color-1000) !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 10px;
            transition: background .2s, transform .1s;
        }

        .btn-primary:hover {
            background: var(--color-900) !important;
            border-color: var(--color-900) !important;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: var(--color-500) !important;
            border-color: var(--color-500) !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 10px;
        }

        .btn-secondary:hover {
            background: var(--color-600) !important;
            border-color: var(--color-600) !important;
        }

        .btn-warning {
            background: var(--color-700) !important;
            border-color: var(--color-700) !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 8px;
        }

        .btn-warning:hover {
            background: var(--color-800) !important;
        }

        .btn-danger {
            background: #b91c1c !important;
            border-color: #b91c1c !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 8px;
        }

        .btn-success {
            background: #15803d !important;
            border-color: #15803d !important;
            color: #fff !important;
            font-weight: 700;
            border-radius: 8px;
        }

        .btn-outline-primary {
            color: var(--color-1000) !important;
            border-color: var(--color-1000) !important;
            font-weight: 700;
            border-radius: 10px;
        }

        .btn-outline-primary:hover {
            background: var(--color-1000) !important;
            color: #fff !important;
        }

        /* ── Cards ── */
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(88,49,1,.1);
            background: #fff;
        }

        .card-header {
            background: var(--color-200);
            border-bottom: 1px solid var(--color-300);
            border-radius: 16px 16px 0 0 !important;
            font-weight: 700;
            color: var(--color-1000);
            padding: 1rem 1.25rem;
        }

        /* ── Stat cards ── */
        .stat-card {
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            box-shadow: 0 3px 12px rgba(88,49,1,.12);
            transition: transform .2s, box-shadow .2s;
            text-decoration: none;
            color: inherit;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(88,49,1,.18);
        }

        .stat-card .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            flex-shrink: 0;
        }

        .stat-card .stat-value {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .stat-card .stat-label {
            font-size: .85rem;
            font-weight: 600;
            opacity: .75;
            margin-top: .2rem;
        }

        .stat-bg-1 { background: var(--color-100); color: var(--color-1000); }
        .stat-bg-2 { background: #fff7ed; color: var(--color-900); }
        .stat-bg-3 { background: #fef3c7; color: #92400e; }
        .stat-bg-4 { background: #dcfce7; color: #14532d; }
        .stat-bg-5 { background: #fee2e2; color: #991b1b; }
        .stat-icon-1 { background: var(--color-300); color: var(--color-1000); }
        .stat-icon-2 { background: var(--color-500); color: #fff; }
        .stat-icon-3 { background: #f59e0b; color: #fff; }
        .stat-icon-4 { background: #22c55e; color: #fff; }
        .stat-icon-5 { background: #ef4444; color: #fff; }

        /* ── Tables ── */
        .table {
            font-size: .9rem;
        }

        .table thead th {
            background: var(--color-200);
            color: var(--color-1000);
            font-weight: 700;
            border: none;
            padding: .85rem 1rem;
        }

        .table tbody td {
            padding: .75rem 1rem;
            vertical-align: middle;
            border-color: var(--color-100);
        }

        .table tbody tr:hover {
            background: #fffaf5;
        }

        /* ── Badges ── */
        .badge-active {
            background: #dcfce7;
            color: #15803d;
            font-size: .78rem;
            font-weight: 700;
            padding: .3rem .7rem;
            border-radius: 20px;
        }

        .badge-paused {
            background: #fef3c7;
            color: #92400e;
            font-size: .78rem;
            font-weight: 700;
            padding: .3rem .7rem;
            border-radius: 20px;
        }

        .badge-inactive {
            background: #fee2e2;
            color: #991b1b;
            font-size: .78rem;
            font-weight: 700;
            padding: .3rem .7rem;
            border-radius: 20px;
        }

        /* ── Forms ── */
        .form-label {
            font-weight: 600;
            color: var(--color-800);
            font-size: .9rem;
        }

        .form-control, .form-select {
            border-radius: 10px;
            border-color: var(--color-300);
            font-family: 'Cairo', sans-serif;
            font-size: .9rem;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--color-600);
            box-shadow: 0 0 0 3px rgba(164,113,72,.15);
        }

        /* ── Alerts ── */
        .alert {
            border-radius: 12px;
            border: none;
            font-weight: 600;
        }

        .alert-success {
            background: #dcfce7;
            color: #15803d;
        }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        /* ── Misc ── */
        .navbar-toggler {
            border-color: var(--color-600) !important;
        }

        .navbar-toggler-icon {
            filter: invert(1);
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg admin-navbar">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="CentralAdmin" asp-action="Index">
                <i class="bi bi-mortarboard-fill"></i>
                Omia Admin
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNav">
                <ul class="navbar-nav me-auto gap-1 my-2 my-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="CentralAdmin" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>لوحة التحكم
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Details" ? "active" : "")"
                           asp-controller="CentralAdmin" asp-action="Details">
                            <i class="bi bi-bar-chart-line me-1"></i>الإحصاءات التفصيلية
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Institutes" ? "active" : "")"
                           asp-controller="CentralAdmin" asp-action="Institutes">
                            <i class="bi bi-building me-1"></i>المعاهد
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Teacher") == true ? "active" : "")"
                           asp-controller="CentralAdmin" asp-action="Teachers">
                            <i class="bi bi-person-video3 me-1"></i>المدرسون
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Admin") == true ? "active" : "")"
                           asp-controller="CentralAdmin" asp-action="Admins">
                            <i class="bi bi-shield-lock me-1"></i>المسؤولون
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="navbar-text">
                        <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("AdminName")
                    </span>
                    <a class="btn-logout" asp-controller="CentralAdmin" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i>خروج
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@TempData["Error"]</span>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
