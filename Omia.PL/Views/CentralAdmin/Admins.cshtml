@model IEnumerable<Omia.PL.ViewModels.CentralAdmin.AdminListViewModel>
@{
    ViewData["Title"] = "إدارة المسؤولين";
    var currentAdminId = Context.Session.GetString("AdminId");
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-shield-lock me-2"></i>إدارة المسؤولين</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">لوحة التحكم</a></li>
                <li class="breadcrumb-item active">المسؤولون</li>
            </ol>
        </nav>
    </div>
    <a asp-action="AdminCreate" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>إضافة مسؤول جديد
    </a>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>قائمة المسؤولين</span>
        <span style="font-size:.85rem;color:#888;">الإجمالي: @Model.Count()</span>
    </div>
    @if (Model.Any())
    {
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الاسم الكامل</th>
                            <th>اسم المستخدم</th>
                            <th>البريد / الهاتف</th>
                            <th>الحالة</th>
                            <th>تاريخ الإنشاء</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int idx = 1; }
                        @foreach (var item in Model)
                        {
                            var isSelf = item.Id.ToString() == currentAdminId;
                            <tr @(isSelf ? "style=background:#fffaf0;" : "")>
                                <td>@(idx++)</td>
                                <td>
                                    <strong>@item.FullName</strong>
                                    @if (isSelf)
                                    { <span style="font-size:.75rem;color:#A47148;margin-right:.4rem;font-weight:700;">(أنت)</span> }
                                </td>
                                <td style="font-family:monospace;font-size:.85rem;">@item.Username</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Email))
                                    { <div><i class="bi bi-envelope me-1" style="color:#A47148;"></i>@item.Email</div> }
                                    @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                    { <div><i class="bi bi-telephone me-1" style="color:#A47148;"></i>@item.PhoneNumber</div> }
                                </td>
                                <td>
                                    @if (item.Status == "Active")
                                    { <span class="badge-active">نشط</span> }
                                    else
                                    { <span class="badge-paused">موقوف</span> }
                                </td>
                                <td style="font-size:.82rem;color:#888;">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <a asp-action="AdminEdit" asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm" title="تعديل">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!isSelf)
                                        {
                                            <form asp-action="AdminToggleStatus" asp-route-id="@item.Id" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm @(item.Status == "Active" ? "btn-secondary" : "btn-success")"
                                                        title="@(item.Status == "Active" ? "إيقاف" : "تفعيل")">
                                                    <i class="bi @(item.Status == "Active" ? "bi-pause-fill" : "bi-play-fill")"></i>
                                                </button>
                                            </form>
                                            <form asp-action="AdminDelete" asp-route-id="@item.Id" method="post" style="display:inline;"
                                                  onsubmit="return confirm('هل أنت متأكد من حذف هذا المسؤول؟');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm" title="حذف">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card-body text-center py-5" style="color:#A47148;">
            <i class="bi bi-shield-lock" style="font-size:3rem;"></i>
            <p class="mt-3 mb-3 fw-bold">لا يوجد مسؤولون آخرون</p>
            <a asp-action="AdminCreate" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>إضافة مسؤول جديد
            </a>
        </div>
    }
</div>
