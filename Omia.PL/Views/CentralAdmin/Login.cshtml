@model Omia.PL.ViewModels.CentralAdmin.LoginViewModel
@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "تسجيل الدخول";
}

<div style="width: 100%; max-width: 430px; padding: 1rem;">
    <div class="card" style="border-radius: 20px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,.3);">
        <!-- Header -->
        <div style="background: #583101; padding: 2.5rem 2rem; text-align: center;">
            <div style="width:70px;height:70px;border-radius:50%;background:#FFEED8;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:2rem;color:#583101;">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h1 style="color:#FFEED8;font-size:1.5rem;font-weight:800;margin:0;">لوحة الإدارة المركزية</h1>
            <p style="color:#E7BC91;margin:.4rem 0 0;font-size:.9rem;">Omia Education Platform</p>
        </div>

        <!-- Form -->
        <div style="padding: 2rem;">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert" style="background:#fee2e2;color:#991b1b;border-radius:10px;padding:.75rem 1rem;font-size:.9rem;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;">
                    <span>⚠️</span>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Username" style="font-weight:700;color:#583101;font-size:.9rem;display:block;margin-bottom:.4rem;"></label>
                    <div style="position:relative;">
                        <span style="position:absolute;right:.85rem;top:50%;transform:translateY(-50%);color:#A47148;font-size:1rem;"><i class="bi bi-person"></i></span>
                        <input asp-for="Username" class="form-control"
                               style="padding-right:2.5rem;border-radius:10px;border:2px solid #E7BC91;font-family:'Cairo',sans-serif;"
                               placeholder="أدخل اسم المستخدم" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Username" style="color:#b91c1c;font-size:.8rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" style="font-weight:700;color:#583101;font-size:.9rem;display:block;margin-bottom:.4rem;"></label>
                    <div style="position:relative;">
                        <span style="position:absolute;right:.85rem;top:50%;transform:translateY(-50%);color:#A47148;font-size:1rem;"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control"
                               style="padding-right:2.5rem;border-radius:10px;border:2px solid #E7BC91;font-family:'Cairo',sans-serif;"
                               placeholder="أدخل كلمة المرور" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" style="color:#b91c1c;font-size:.8rem;"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100"
                        style="background:#583101;border-color:#583101;border-radius:12px;padding:.75rem;font-size:1rem;font-weight:800;font-family:'Cairo',sans-serif;transition:background .2s;">
                    دخول &nbsp; →
                </button>
            </form>
        </div>
    </div>
    <p style="text-align:center;color:rgba(255,238,216,.6);font-size:.8rem;margin-top:1.25rem;">
        © @DateTime.Now.Year Omia Education Platform
    </p>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
